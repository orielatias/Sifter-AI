# ============================================
# AI Intelligence Engine — Environment Config
# ============================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Supabase (PostgreSQL) ──
# Get these from: https://supabase.com → Project Settings → Database
SUPABASE_DB_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct connection (for migrations only — bypasses connection pooler)
SUPABASE_DB_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Qdrant Cloud ──
# Get these from: https://cloud.qdrant.io → Cluster → API Keys
QDRANT_URL=https://your-cluster-id.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# ── Anthropic (Claude API) ──
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (Embeddings) ──
# Get from: https://dash.voyageai.com → API Keys
# Alternative: set OPENAI_API_KEY instead and change embedding config
VOYAGE_API_KEY=pa-...

# ── Resend (Email) ──
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
DIGEST_FROM_EMAIL=digest@yourdomain.com
DIGEST_TO_EMAILS=you@example.com

# ── Reddit API ──
# Create an app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USER_AGENT=ai-intel-engine/0.1 by u/yourusername

# ── YouTube Data API ──
# Get from: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# ── App Config ──
LOG_LEVEL=INFO
ENVIRONMENT=development
DIGEST_SCHEDULE=daily
# How many top signals to include in each digest
TOP_SIGNALS_COUNT=10
# Minimum relevance score (1-10) for digest consideration
MIN_RELEVANCE_SCORE=7
